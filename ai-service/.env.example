PORT=8000
PYTHONUNBUFFERED=1

# Shared secret expected from backend in X-API-KEY header
AI_SERVICE_API_KEY=replace-with-shared-ai-service-key

# Enforce API key authentication for scoring/bias/parse endpoints
AI_REQUIRE_API_KEY=true

# Comma-separated CORS origins
AI_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Durable multi-step session store for /upload_jd → /upload_resume → /get_rankings
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=86400
